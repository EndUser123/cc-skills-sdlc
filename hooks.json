{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/skills/refactor/hooks/PostToolUse_refactor_transition.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/skills/refactor/hooks/PostToolUse_refactor_validator.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/skills/code_v3.0/hooks/PreToolUse_plan_consumer_gate.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/skills/refactor/hooks/PreToolUse_refactor_gate.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/skills/refactor/hooks/Stop_refactor_verifier.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/skills/pre-mortem/hooks/Stop_hook_premortem_quality_gate.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/skills/rca/hooks/SessionEnd_rca_cleanup.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/skills/code_v3.0/hooks/SessionStart_breadcrumb_init.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
