{
  "_comment": "Behavior gates configuration for /code skill - Detects implementation commitments vs guidance",
  "_version": "2.0",
  "_last_updated": "2026-03-01",

  "agreement_patterns": {
    "_comment": "Patterns that indicate direct implementation commitments (violations when agent delegates)",
    "direct_commitments": [
      "\\bI'll\\s+(?:update|fix|edit|modify|change|create|write|add|remove|delete|implement|refactor|optimize)\\b",
      "\\bLet\\s+me\\s+(?:update|fix|edit|modify|change|create|write|add|remove|delete)\\b",
      "\\bI\\s+(?:will|shall)\\s+(?:update|fix|edit|modify|change|create|write|implement)\\b"
    ],
    "excluded_patterns": {
      "_comment": "Patterns that should NOT trigger gates (false positives to exclude)",
      "test_writing": [
        "\\bI'll\\s+(?:write|create|add)\\s+(?:a\\s+)?test\\b",
        "\\bI'll\\s+(?:write|create)\\s+tests?\b",
        "\\bLet\\s+me\\s+(?:write|create)\\s+(?:a\\s+)?test\\b",
        "\\bI\\s+(?:will|shall)\\s+(?:write|create)\\s+(?:a\\s+)?test\\b",
        "\\b(?:writing|creating)\\s+(?:a\\s+)?test\\b"
      ],
      "guidance_and_planning": [
        "\\bI'll\\s+(?:check|verify|validate|review|examine|inspect)\\b",
        "\\bLet\\s+me\\s+(?:check|verify|validate|review|see|look\\s+at)\\b",
        "\\bI'll\\s+show\\s+you\\b",
        "\\bLet\\s+me\\s+show\\s+you\\b",
        "\\bI\\s+(?:will|shall)\\s+(?:check|verify|validate|review)\\b"
      ],
      "questions": [
        "\\bshould\\s+I\\s+(?:write|create|add|modify|change)\\b",
        "\\bdo\\s+you\\s+want\\s+me\\s+to\\b",
        "\\bwould\\s+you\\s+like\\s+me\\s+to\\b",
        "\\bcan\\s+I\\s+(?:help|assist)\\b"
      ],
      "delegation": [
        "\\bI'll\\s+(?:dispatch|delegate|call|invoke|use|run)\\s+(?:the|a|an)?\\s+(?:Task\\s+tool|agent|subagent)\\b",
        "\\bLet\\s+me\\s+(?:dispatch|delegate|call|invoke|use|run)\\s+(?:the|a|an)?\\s+(?:Task\\s+tool|agent|subagent)\\b",
        "\\busing\\s+(?:the|a|an)?\\s+Task\\s+tool\\b",
        "\\bvia\\s+(?:the|a|an)?\\s+Task\\s+tool\\b"
      ]
    }
  },

  "guidance_patterns": {
    "_comment": "Patterns that indicate directive guidance to user (acceptable - user implements)",
    "direct_guidance": [
      "\\byou\\s+should\\s+(?:modify|change|update|edit|fix|add|remove|delete)\\b",
      "\\bmodify\\s+the\\s+(?:function|method|class|variable|parameter)\\b",
      "\\bchange\\s+the\\s+(?:configuration|config|settings?)\\b",
      "\\bthe\\s+issue\\s+is\\s+in\\b",
      "\\bthe\\s+problem\\s+is\\s+(?:in|at|with)\\b",
      "\\byou\\s+need\\s+to\\s+(?:update|edit|modify|fix)\\b",
      "\\btry\\s+(?:modifying|changing|updating|editing)\\b",
      "\\bgo\\s+to\\s+(?:the\\s+)?(?:file|function|method)\\b",
      "\\bin\\s+[\\w./]+\\s+(?:you\\s+should|try|change|modify)\\b",
      "\\bfix\\s+the\\s+(?:function|method|class|code)\\b"
    ],
    "excluded_patterns": {
      "_comment": "Patterns that are NOT guidance (examples, explanations, test suggestions)",
      "test_suggestions": [
        "\\byou\\s+should\\s+(?:write|create|add)\\s+(?:a\\s+)?test\\b",
        "\\byou\\s+need\\s+to\\s+(?:write|create|add)\\s+(?:a\\s+)?test\\b",
        "\\btry\\s+(?:writing|creating)\\s+(?:a\\s+)?test\\b"
      ],
      "explanations": [
        "\\byou\\s+can\\s+(?:see|check|verify|use|try)\\b",
        "\\bto\\s+(?:see|check|verify|use)\\b",
        "\\bfor\\s+(?:example|instance)\\b"
      ]
    }
  },

  "tdd_context": {
    "_comment": "TDD-specific context awareness - distinguishes test-writing from implementation",
    "red_phase_indicators": [
      "\\b(?:writing|creating)\\s+(?:a\\s+)?test\\b",
      "\\btest\\s+(?:writing|creation|development)\\b",
      "\\bRED\\s+phase\\b",
      "\\bfailing\\s+test\\b"
    ],
    "implementation_phase_indicators": [
      "\\b(?:implementing|implementation)\\b",
      "\\b(?:fixing|fix)\\s+(?:the\\s+)?(?:test|code)\\b",
      "\\bGREEN\\s+phase\\b",
      "\\bpassing\\s+test\\b",
      "\\brefactoring\\b",
      "\\bREFACTOR\\s+phase\\b"
    ]
  },

  "code_skill_context": {
    "_comment": "/code skill-specific patterns - workflow and phase terminology",
    "phase_names": [
      "\\bBOOTSTRAP\\s+phase\\b",
      "\\bALIGN\\s+phase\\b",
      "\\bDESIGN\\s+phase\\b",
      "\\bBUILD\\s+phase\\b",
      "\\bTRACE\\s+phase\\b",
      "\\bSHIP\\s+phase\\b"
    ],
    "workflow_terms": [
      "\\b(?:task|plan)\\s+(?:list|item)\\b",
      "\\bevidence\\s+(?:ledger|types?)\\b",
      "\\bphase\\s+(?:state|manager|marker)\\b",
      "\\bresume\\s+ledger\\b",
      "\\bexecution\\s+model\\b"
    ]
  },

  "tool_blacklist": {
    "_comment": "Tools that trigger behavioral gate violations when used inappropriately",
    "task_tool_without_delegation": [
      "\\bTask\\s+tool\\b(?!\\s+(?:when\\s+(?:appropriate|useful)|for\\s+(?:parallel|focused)))"
    ]
  },

  "context_awareness": {
    "_comment": "Contextual factors that affect gate interpretation",
    "execution_model_keywords": {
      "subagent": [
        "\\bsubagent\\b",
        "\\bagent\\s+dispatch\\b",
        "\\bTask\\s+tool\\b"
      ],
      "team": [
        "\\bagent\\s+team\\b",
        "\\bteammate\\b",
        "\\bparallel\\s+(?:agents|execution)\\b"
      ]
    },
    "role_keywords": {
      "lead": [
        "\\b(?:I'll|I\\s+will)\\s+(?:coordinate|orchestrate|manage)\\b",
        "\\b(?:dispatching|delegating)\\s+to\\b"
      ],
      "implementer": [
        "\\b(?:I'll|I\\s+will)\\s+(?:implement|write|code|fix)\\b"
      ]
    }
  }
}
