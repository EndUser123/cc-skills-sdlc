{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DeepSeek V3.2 Code Critique Findings",
  "description": "Schema for DeepSeek V3.2 code critique findings in the /code AUDIT phase. Consistent with deepseek-adversarial-schema.json.",
  "type": "object",
  "required": ["schema_version", "reviewer", "files_reviewed", "confidence_threshold", "findings", "summary"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version identifier. Must be '1.0'."
    },
    "reviewer": {
      "type": "string",
      "const": "deepseek-v3.2",
      "description": "Reviewer identifier."
    },
    "files_reviewed": {
      "type": "array",
      "description": "List of files that were reviewed.",
      "items": { "type": "string" }
    },
    "confidence_threshold": {
      "type": "integer",
      "const": 80,
      "description": "Minimum confidence threshold applied to findings."
    },
    "findings": {
      "type": "array",
      "description": "List of code review findings.",
      "items": {
        "type": "object",
        "required": ["severity", "issue"],
        "additionalProperties": true,
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["HIGH", "MEDIUM", "LOW"],
            "description": "Severity level of the finding."
          },
          "file": {
            "type": "string",
            "description": "File path where the issue was found."
          },
          "line": {
            "type": ["integer", "string"],
            "description": "Line number or range where the issue was found."
          },
          "issue": {
            "type": "string",
            "description": "Description of the issue found."
          },
          "recommendation": {
            "type": "string",
            "description": "Recommended fix for the issue."
          }
        }
      }
    },
    "summary": {
      "type": "string",
      "description": "One to two sentence summary of the review."
    }
  }
}
