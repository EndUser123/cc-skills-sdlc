{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/go/selected-task.schema.json",
  "title": "GoSelectedTask",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "go_run_id",
    "terminal_id",
    "task_id",
    "title",
    "objective",
    "task_type",
    "source",
    "source_ref",
    "scope_in",
    "scope_out",
    "acceptance_criteria",
    "verification_hint",
    "blocked_by",
    "status",
    "selected_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "go.selected-task.v1"
    },
    "go_run_id": {
      "type": "string",
      "minLength": 1
    },
    "terminal_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "objective": {
      "type": "string",
      "minLength": 5
    },
    "task_type": {
      "type": "string",
      "enum": [
        "planning",
        "design",
        "implementation",
        "refactor",
        "unknown"
      ]
    },
    "source": {
      "type": "string",
      "enum": [
        "structured-plan",
        "plan-md",
        "plan.md",
        "conversation",
        "git-context",
        "manual"
      ]
    },
    "source_ref": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "in": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "out": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "scope_in": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "scope_out": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "allowed_files": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verification_hint": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_files": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "candidate_routes": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string",
        "enum": [
          "planning",
          "design_v1.1",
          "code",
          "refactor"
        ]
      },
      "uniqueItems": true
    },
    "blocked_by": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "const": "selected"
    },
    "selected_at": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  }
}
