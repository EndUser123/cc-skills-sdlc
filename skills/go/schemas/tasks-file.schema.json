{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/go/tasks-file.schema.json",
  "title": "GoTasksFile",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "tasks"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "objective", "status", "priority", "scope_in", "scope_out", "forbidden_files", "acceptance_criteria"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._:-]+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "objective": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["ready", "queued", "approved", "selected", "completed", "blocked"]
          },
          "priority": {
            "type": "string",
            "pattern": "^P[0-9]+$"
          },
          "scope_in": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          },
          "scope_out": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          },
          "forbidden_files": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          },
          "acceptance_criteria": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          },
          "verification_commands": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          },
          "requires_approval": {
            "type": "boolean",
            "default": false
          },
          "selected_by": {
            "type": "string",
            "minLength": 1
          },
          "selected_at": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
