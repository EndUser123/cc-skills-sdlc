{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/go/verification-result.schema.json",
  "title": "GoVerificationResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "terminal_id",
    "task_id",
    "status",
    "generated_at"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "terminal_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["pending", "passed", "failed", "blocked", "waived"]
    },
    "pr_ready": {
      "type": "boolean",
      "default": false
    },
    "verification_commands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "exit_code", "passed"],
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "exit_code": {
            "type": "integer"
          },
          "passed": {
            "type": "boolean"
          },
          "artifact_path": {
            "type": "string"
          },
          "elapsed_ms": {
            "type": "integer"
          }
        }
      },
      "default": []
    },
    "simplify": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "skipped"]
        },
        "findings_summary": {
          "type": "string"
        },
        "artifact_path": {
          "type": "string"
        }
      }
    },
    "review_passes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "correctness": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": {
              "type": "string",
              "enum": ["passed", "failed", "skipped"]
            },
            "artifact_path": {
              "type": "string"
            }
          }
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": {
              "type": "string",
              "enum": ["passed", "failed", "skipped"]
            },
            "artifact_path": {
              "type": "string"
            }
          }
        },
        "tests": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": {
              "type": "string",
              "enum": ["passed", "failed", "skipped"]
            },
            "artifact_path": {
              "type": "string"
            }
          }
        },
        "simplicity": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": {
              "type": "string",
              "enum": ["passed", "failed", "skipped"]
            },
            "artifact_path": {
              "type": "string"
            }
          }
        },
        "regressions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": {
              "type": "string",
              "enum": ["passed", "failed", "skipped"]
            },
            "artifact_path": {
              "type": "string"
            }
          }
        },
        "maintainability": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": {
              "type": "string",
              "enum": ["passed", "failed", "skipped"]
            },
            "artifact_path": {
              "type": "string"
            }
          }
        },
        "pr_ready": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": {
              "type": "string",
              "enum": ["passed", "failed", "skipped"]
            },
            "artifact_path": {
              "type": "string"
            }
          }
        }
      }
    },
    "tdd": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "boolean",
          "default": true
        },
        "run_id": {
          "type": "string"
        },
        "validated": {
          "type": "boolean",
          "default": false
        },
        "validated_artifact": {
          "type": "string"
        },
        "phase_state": {
          "type": "string",
          "enum": ["red", "green", "refactor", "none"]
        }
      }
    },
    "mutation": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional side-channel mutation-testing block (mutmut 3.x). Present when the run executed a mutation phase for a target module.",
      "properties": {
        "module": {
          "type": "string",
          "minLength": 1
        },
        "tier": {
          "type": "string",
          "enum": ["critical", "standard", "best-effort"]
        },
        "target_score": {
          "type": ["integer", "null"],
          "minimum": 0,
          "maximum": 100
        },
        "mutation_score": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 100
        },
        "killed": {
          "type": "integer",
          "minimum": 0
        },
        "survived": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        },
        "timeout": {
          "type": "integer",
          "minimum": 0
        },
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "waived", "skipped", "timeout", "blocked", "not-run"]
        },
        "receipt_path": {
          "type": "string"
        }
      }
    },
    "integration_verification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "skipped", "none"]
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "artifact_paths": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "verification_log": {
          "type": "string"
        },
        "simplify_log": {
          "type": "string"
        },
        "review_log": {
          "type": "string"
        },
        "tdd_receipt": {
          "type": "string"
        },
        "mutation_gate": {
          "type": "string"
        },
        "pr_ready": {
          "type": "string"
        },
        "capability_audit": {
          "type": "string"
        }
      }
    },
    "capability_audit": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional capability-claim audit block. Present when the task involved command consolidation, deprecation, absorption, routing, or cleanup.",
      "properties": {
        "audit_passed": {
          "type": "boolean",
          "description": "True only when every non-deferred claim is verified against real implementation paths."
        },
        "claims": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["command", "classification", "status"],
            "properties": {
              "command": {
                "type": "string",
                "minLength": 1
              },
              "classification": {
                "type": "string",
                "enum": [
                  "true_stub",
                  "deprecation_header_on_retained_engine",
                  "retained_engine",
                  "routed_to_parent",
                  "pending_backend",
                  "deleted",
                  "unknown"
                ]
              },
              "source_path": {
                "type": "string"
              },
              "parent_path": {
                "type": "string"
              },
              "routing_mechanism": {
                "type": "string"
              },
              "backend_path": {
                "type": "string"
              },
              "backend_exists": {
                "type": "boolean",
                "description": "Whether the backend runner/module/function path resolves to a real file."
              },
              "status": {
                "type": "string",
                "enum": ["verified", "overclaim", "deferred", "not_checked"]
              },
              "evidence": {
                "type": "string",
                "description": "Human-readable evidence for the classification."
              }
            }
          },
          "default": []
        },
        "visible_surface_complete": {
          "type": "boolean",
          "description": "Whether the visible command surface reduction is verified."
        },
        "routing_complete": {
          "type": "boolean",
          "description": "Whether routing to parent/backend is verified."
        },
        "backend_implemented": {
          "type": "boolean",
          "description": "Whether the backend runner/module/function exists and is live."
        },
        "deferred_capabilities": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Capabilities intentionally deferred — allowed only when explicitly marked pending."
        }
      }
    }
  }
}
