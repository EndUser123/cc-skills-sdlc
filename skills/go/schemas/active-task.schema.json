{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/go/active-task.schema.json",
  "title": "GoActiveTask",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "terminal_id",
    "selected_at",
    "task"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "terminal_id": {
      "type": "string",
      "minLength": 1
    },
    "selected_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "source_ref": {
      "type": "string",
      "minLength": 1
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "objective",
        "status",
        "priority",
        "scope_in",
        "scope_out",
        "forbidden_files",
        "acceptance_criteria",
        "verification_commands"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["ready", "queued", "approved", "selected", "completed", "blocked"]
        },
        "priority": {
          "type": "string",
          "pattern": "^P[0-9]+$"
        },
        "scope_in": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "scope_out": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "forbidden_files": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "verification_commands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "task_type": {
          "type": "string",
          "enum": ["planning", "design", "implementation", "refactor", "validation", "audit", "testing", "unknown"],
          "default": "implementation",
          "description": "Routing axis: which skill consumes this task (/code, /refactor, /design, /planning, /t). Orthogonal to task_intent."
        },
        "task_intent": {
          "type": "string",
          "enum": ["implement", "investigate", "validate", "decide", "mixed"],
          "description": "Ceremony/rigor axis: controls execution_tier, verification depth, and completion-claim eligibility. Computed by preflight_propose.classify_intent for prompt-synthesized tasks; may be set explicitly on queued tasks. Missing/ambiguous defaults to 'implement'."
        },
        "selected_by": {
          "type": "string",
          "minLength": 1
        },
        "selected_at": {
          "type": "string",
          "format": "date-time"
        },
        "requires_approval": {
          "type": "boolean",
          "default": false
        },
        "estimated_complexity": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "default": "medium",
          "description": "Task complexity estimate. If 'high', /go must confirm before dispatching to /code."
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Task IDs that must be completed before this task can be dispatched. /go validates all dependencies are completed before routing."
        },
        "notes": {
          "type": "string"
        },
        "done_when": {
          "type": "string",
          "minLength": 1,
          "description": "Single binary observable condition that proves completion. Must be a command whose exit code 0 = done, non-zero = not done. Example: 'pytest tests/test_auth.py'. This is the authoritative completion signal — acceptance_criteria are supplementary."
        },
        "stop_rules": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_turns": {
              "type": "integer",
              "minimum": 1,
              "default": 10,
              "description": "Hard cap on LLM turns (tool-call round-trips) before the task is force-stopped. Prevents infinite loops."
            },
            "max_attempts": {
              "type": "integer",
              "minimum": 1,
              "default": 3,
              "description": "Max retry attempts on verification failure before BLOCKED."
            }
          },
          "description": "Per-task caps to prevent infinite looping. Overrides global MAX_ATTEMPTS when set."
        },
        "output": {
          "type": "string",
          "description": "What to surface when done — summary of changes, test results, or specific artifacts to report."
        }
      }
    }
  }
}
