{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/go/pr-ready.schema.json",
  "title": "GoPrReady",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "title",
    "run_id",
    "status"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["pr_ready"]
    },
    "verification_passed": {
      "type": "boolean",
      "default": true
    },
    "simplify_passed": {
      "type": "boolean",
      "default": true
    },
    "reviews_passed": {
      "type": "boolean",
      "default": true
    },
    "review_depth": {
      "type": "string",
      "enum": ["quick", "standard", "full"]
    },
    "commit_message_file": {
      "type": "string"
    },
    "pr_title_file": {
      "type": "string"
    },
    "pr_body_file": {
      "type": "string"
    },
    "promise": {
      "type": "string",
      "const": "PR_READY"
    }
  }
}
