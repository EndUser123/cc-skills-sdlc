{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/go/dispatch-result.schema.json",
  "title": "GoDispatchResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "go_run_id",
    "terminal_id",
    "task_id",
    "route",
    "delegated_skill",
    "dispatch_status",
    "delegated_at",
    "expected_outcome_type",
    "orchestrator_wait_state",
    "final_status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "go.dispatch-result.v1"
    },
    "go_run_id": {
      "type": "string",
      "minLength": 1
    },
    "terminal_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "route": {
      "type": "string",
      "enum": [
        "planning",
        "design_v1.1",
        "code",
        "refactor"
      ]
    },
    "delegated_skill": {
      "type": "string",
      "enum": [
        "/planning",
        "/design_v1.1",
        "/code",
        "/refactor"
      ]
    },
    "dispatch_status": {
      "type": "string",
      "enum": [
        "dispatched",
        "not-dispatched"
      ]
    },
    "delegated_at": {
      "type": "string",
      "format": "date-time"
    },
    "expected_outcome_type": {
      "type": "string",
      "enum": [
        "plan",
        "adr",
        "implementation",
        "refactor-result",
        "unknown"
      ]
    },
    "orchestrator_wait_state": {
      "type": "string",
      "enum": [
        "awaiting-skill-outcome",
        "outcome-recorded"
      ]
    },
    "final_status": {
      "type": "string",
      "enum": [
        "awaiting",
        "completed",
        "blocked"
      ]
    },
    "completion_summary": {
      "type": "string"
    },
    "produced_artifacts": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "skill_output_refs": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blocking_reason": {
      "type": "string"
    },
    "next_recommended_skill": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "planning",
        "design_v1.1",
        "code",
        "refactor",
        null
      ]
    },
    "next_recommended_action": {
      "type": "string"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "final_status": {
            "const": "completed"
          }
        }
      },
      "then": {
        "required": [
          "completion_summary",
          "next_recommended_action",
          "completed_at"
        ],
        "properties": {
          "orchestrator_wait_state": {
            "const": "outcome-recorded"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "final_status": {
            "const": "blocked"
          }
        }
      },
      "then": {
        "required": [
          "blocking_reason",
          "next_recommended_action"
        ],
        "properties": {
          "orchestrator_wait_state": {
            "const": "outcome-recorded"
          }
        }
      }
    }
  ]
}
