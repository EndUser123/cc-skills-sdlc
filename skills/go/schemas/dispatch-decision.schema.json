{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/go/dispatch-decision.schema.json",
  "title": "GoDispatchDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "go_run_id",
    "terminal_id",
    "task_id",
    "route",
    "delegated_skill",
    "reasoning_short",
    "blocking_preconditions",
    "dispatch_status",
    "decided_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "go.dispatch-decision.v1"
    },
    "go_run_id": {
      "type": "string",
      "minLength": 1
    },
    "terminal_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "route": {
      "type": "string",
      "enum": [
        "planning",
        "design_v1.1",
        "code",
        "refactor"
      ]
    },
    "delegated_skill": {
      "type": "string",
      "enum": [
        "/planning",
        "/design_v1.1",
        "/code",
        "/refactor"
      ]
    },
    "reasoning_short": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "blocking_preconditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decision_inputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "behavior_change_expected": {
          "type": "boolean"
        },
        "architecture_unresolved": {
          "type": "boolean"
        },
        "scope_unclear": {
          "type": "boolean"
        },
        "cleanup_only": {
          "type": "boolean"
        },
        "plan_required": {
          "type": "boolean"
        }
      }
    },
    "dispatch_status": {
      "type": "string",
      "const": "routed"
    },
    "decided_at": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "route": {
            "const": "planning"
          }
        }
      },
      "then": {
        "properties": {
          "delegated_skill": {
            "const": "/planning"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "route": {
            "const": "design_v1.1"
          }
        }
      },
      "then": {
        "properties": {
          "delegated_skill": {
            "const": "/design_v1.1"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "route": {
            "const": "code"
          }
        }
      },
      "then": {
        "properties": {
          "delegated_skill": {
            "const": "/code"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "route": {
            "const": "refactor"
          }
        }
      },
      "then": {
        "properties": {
          "delegated_skill": {
            "const": "/refactor"
          }
        }
      }
    }
  ]
}
