{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/go/code-result.schema.json",
  "title": "GoCodeResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "task_id",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "go.code-result.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["success", "partial", "failed", "skipped"]
    },
    "subtask_id": {
      "type": "string"
    },
    "files_modified": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "change_type"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "change_type": {
            "type": "string",
            "enum": ["created", "modified", "deleted", "renamed"]
          },
          "lines_added": {
            "type": "integer",
            "minimum": 0
          },
          "lines_removed": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "default": []
    },
    "tests_executed": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "passed": {
            "type": "boolean"
          },
          "duration_ms": {
            "type": "integer"
          }
        }
      },
      "default": []
    },
    "artifacts_written": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "issues_found": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["error", "warning", "info"]
          },
          "description": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "line": {
            "type": "integer"
          }
        }
      },
      "default": []
    },
    "next_action": {
      "type": "string",
      "enum": ["none", "review", "test", "refactor", "verify", "complete"]
    },
    "needs_tdd": {
      "type": "boolean",
      "default": false
    },
    "needs_refactor": {
      "type": "boolean",
      "default": false
    },
    "verification_pending": {
      "type": "boolean",
      "default": false
    },
    "summary": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}